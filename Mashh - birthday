<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday Pookie ❤️</title>

<link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Poppins:wght@300;400;500;600&family=Pacifico&family=Chewy&family=Indie+Flower&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
}

body{
overflow-x:hidden;
background:black;
}

section{
width:100%;
min-height:100vh;
padding:30px 20px;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
position:relative;
overflow:hidden;
}

img{
max-width:100%;
}

.next-btn,.back-btn{
position:absolute;
bottom:20px;
padding:12px 22px;
border:none;
border-radius:40px;
font-size:15px;
font-weight:bold;
cursor:pointer;
background:white;
box-shadow:0 0 15px rgba(0,0,0,0.2);
transition:0.3s;
}

.next-btn:hover,.back-btn:hover{
transform:scale(1.08);
}

.next-btn{
right:20px;
}

.back-btn{
left:20px;
}

.fade-up{
animation:fadeUp 1.5s ease;
}

.fade-left{
animation:fadeLeft 1.5s ease;
}

.fade-right{
animation:fadeRight 1.5s ease;
}

@keyframes fadeUp{
from{opacity:0;transform:translateY(80px)}
to{opacity:1;transform:translateY(0)}
}

@keyframes fadeLeft{
from{opacity:0;transform:translateX(-80px)}
to{opacity:1;transform:translateX(0)}
}

@keyframes fadeRight{
from{opacity:0;transform:translateX(80px)}
to{opacity:1;transform:translateX(0)}
}

/* PAGE 1 */

#page1{
background:linear-gradient(135deg,#ffe45c,#fff6c7);
font-family:'Pacifico',cursive;
text-align:center;
}

.flower{
position:absolute;
font-size:40px;
animation:float 6s infinite ease-in-out;
}

@keyframes float{
50%{transform:translateY(-20px)}
}

.main-photo{
width:320px;
border-radius:30px;
box-shadow:0 0 30px rgba(0,0,0,0.2);
margin-top:30px;
}

.title1{
font-size:55px;
color:#ff5e7e;
text-shadow:2px 2px white;
}

/* PAGE 2 */

#page2{
background:repeating-linear-gradient(
45deg,
#fff 0px,
#fff 30px,
#ffe96e 30px,
#ffe96e 60px
);
font-family:'Indie Flower',cursive;
}

.duck{
position:absolute;
left:10px;
top:120px;
font-size:70px;
}

.duck-board{
background:white;
padding:12px;
border-radius:20px;
font-size:18px;
width:140px;
box-shadow:0 0 15px rgba(0,0,0,0.15);
}

.page2-title{
font-size:38px;
text-align:center;
margin-bottom:30px;
color:#ff4081;
}

.photo-row{
display:flex;
gap:20px;
flex-wrap:wrap;
justify-content:center;
}

.photo-row img{
width:260px;
border-radius:25px;
box-shadow:0 0 25px rgba(0,0,0,0.2);
}

/* PAGE 3 */

#page3{
background:linear-gradient(135deg,#ff2d55,#fff0f3);
font-family:'Chewy',cursive;
}

.hearts span{
position:absolute;
font-size:25px;
animation:heartFloat 8s linear infinite;
}

@keyframes heartFloat{
from{transform:translateY(100vh)}
to{transform:translateY(-120vh)}
}

.page3-title{
font-size:60px;
color:white;
margin-bottom:25px;
}

.bottom-text{
font-size:45px;
margin-top:30px;
color:#ff004c;
}

/* PAGE 4 */

#page4{
background:linear-gradient(135deg,#89cff0,#d9f5ff);
font-family:'Poppins',sans-serif;
}

.cake-area{
display:flex;
flex-wrap:wrap;
align-items:center;
justify-content:center;
gap:30px;
}

.cake{
font-size:130px;
animation:bounce 2s infinite;
}

@keyframes bounce{
50%{transform:translateY(-15px)}
}

.cake-text{
font-size:28px;
max-width:450px;
color:#00334e;
font-weight:600;
}

/* PAGE 5 */

#page5{
background:linear-gradient(135deg,#ff7b00,#ffd000,#ff3c38);
font-family:'Dancing Script',cursive;
}

.bouquet-area{
display:flex;
flex-wrap:wrap;
justify-content:center;
align-items:center;
gap:30px;
}

.bouquet{
font-size:180px;
position:relative;
}

.flowers-note{
position:absolute;
bottom:0;
right:-30px;
font-size:18px;
background:white;
padding:8px;
border-radius:12px;
font-family:'Indie Flower',cursive;
}

.para{
max-width:450px;
font-size:35px;
color:white;
line-height:1.5;
}

/* PAGE 6 */

#page6{
background:linear-gradient(135deg,#e0c3fc,#8ec5fc);
font-family:'Pacifico',cursive;
}

.badge-title{
font-size:55px;
color:white;
margin-bottom:30px;
text-align:center;
}

.explore-btn{
padding:18px 35px;
border:none;
border-radius:50px;
font-size:22px;
background:#ff5ea8;
color:white;
box-shadow:0 0 20px rgba(255,255,255,0.5);
}

/* PAGE 7 */

#page7{
background:#fff0f6;
font-family:'Poppins',sans-serif;
}

.circle-container{
display:flex;
flex-wrap:wrap;
gap:30px;
justify-content:center;
}

.circle{
width:250px;
height:250px;
border-radius:50%;
display:flex;
justify-content:center;
align-items:center;
font-size:90px;
box-shadow:0 0 20px rgba(0,0,0,0.15);
}

.circle1,.circle3{
background:#ffb6d9;
}

.circle2{
background:#fff3b0;
}

.circle-text{
text-align:center;
margin-top:15px;
font-size:20px;
font-weight:bold;
}

/* PAGE 8 */

#page8{
background:linear-gradient(135deg,#ffd6ec,#ffe8a3,#ffc4d6);
font-family:'Chewy',cursive;
}

.memory-title{
font-size:50px;
color:#ff006e;
margin-bottom:30px;
text-align:center;
}

.memory-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
width:100%;
max-width:1100px;
}

.memory-grid img{
width:100%;
border-radius:25px;
box-shadow:0 0 20px rgba(0,0,0,0.2);
}

.cute-line{
font-size:22px;
text-align:center;
color:#ff4081;
}

/* PAGE 9 */

#page9{
background:linear-gradient(135deg,#fff1eb,#ace0f9);
font-family:'Indie Flower',cursive;
}

.letter-box{
background:#fffaf0;
padding:40px;
border-radius:30px;
max-width:700px;
box-shadow:0 0 30px rgba(0,0,0,0.15);
position:relative;
}

.letter-tag{
position:absolute;
right:-20px;
top:-20px;
background:#ff5ea8;
color:white;
padding:10px 20px;
border-radius:20px;
font-size:22px;
}

.letter-text{
font-size:28px;
line-height:1.8;
color:#444;
}

.open-btn{
margin-top:20px;
padding:12px 25px;
border:none;
border-radius:40px;
background:#ff5ea8;
color:white;
font-size:20px;
}

/* PAGE 10 */

#page10{
background:linear-gradient(135deg,#ffc6ff,#ffd6a5,#fdffb6);
font-family:'Pacifico',cursive;
text-align:center;
}

.uno-card{
background:#ff0033;
padding:50px 30px;
border-radius:40px;
max-width:700px;
color:white;
box-shadow:0 0 40px rgba(0,0,0,0.2);
position:relative;
}

.uno-card::before{
content:'UNO';
position:absolute;
top:15px;
left:20px;
font-size:35px;
transform:rotate(-15deg);
}

.final-title{
font-size:55px;
margin-bottom:20px;
}

.final-text{
font-size:28px;
line-height:1.8;
}

@media(max-width:768px){
.title1,.page3-title,.badge-title,.final-title{
font-size:40px;
}

.bottom-text{
font-size:30px;
}

.para,.letter-text,.cake-text,.final-text{
font-size:22px;
}
}

</style>
</head>

